/* =====================================
   JOEL AGENCY
   APPLE INSPIRED LIQUID GLASS
===================================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{

    font-family:"Inter",sans-serif;
    background:#09090b;
    color:#fff;
    overflow-x:hidden;

}

/* ==========================
   BACKGROUND
========================== */

.background-blur{

    position:fixed;
    width:500px;
    height:500px;
    border-radius:50%;
    filter:blur(180px);
    opacity:.35;
    z-index:-1;

}

.blur1{

    background:#2b7cff;
    top:-180px;
    left:-180px;
    animation:floatOne 14s ease-in-out infinite alternate;

}

.blur2{

    background:#8b5cf6;
    bottom:-180px;
    right:-180px;
    animation:floatTwo 16s ease-in-out infinite alternate;

}

@keyframes floatOne{

0%{transform:translate(0,0);}
100%{transform:translate(150px,120px);}

}

@keyframes floatTwo{

0%{transform:translate(0,0);}
100%{transform:translate(-150px,-100px);}

}

/* ==========================
   NAVBAR
========================== */

header{

    position:fixed;
    width:100%;
    top:0;
    left:0;
    z-index:999;

}

.navbar{

    width:92%;
    max-width:1300px;

    margin:20px auto;

    display:flex;
    justify-content:space-between;
    align-items:center;

    padding:18px 28px;

    border-radius:22px;

    background:rgba(255,255,255,.08);

    backdrop-filter:blur(25px);

    border:1px solid rgba(255,255,255,.12);

    transition:.4s;

}

.logo{

    font-size:28px;
    font-weight:800;
    letter-spacing:-1px;

}

.nav-links{

    display:flex;
    list-style:none;
    gap:35px;

}

.nav-links a{

    color:white;
    text-decoration:none;
    transition:.35s;

}

.nav-links a:hover{

    color:#6eb8ff;

}

.btn{

    text-decoration:none;

    background:white;

    color:#111;

    padding:14px 28px;

    border-radius:999px;

    font-weight:700;

    transition:.35s;

    display:inline-block;

}

.btn:hover{

    transform:translateY(-3px);

    box-shadow:0 15px 40px rgba(255,255,255,.18);

}

/* ==========================
   GLASS BUTTON
========================== */

.glass-btn{

    display:inline-block;

    text-decoration:none;

    padding:14px 28px;

    border-radius:999px;

    color:white;

    background:rgba(255,255,255,.08);

    border:1px solid rgba(255,255,255,.15);

    backdrop-filter:blur(18px);

    transition:.35s;

}

.glass-btn:hover{

    background:rgba(255,255,255,.16);

    transform:translateY(-3px);

}

/* ==========================
   HERO
========================== */

.hero{

    min-height:100vh;

    display:grid;

    grid-template-columns:1.2fr .8fr;

    align-items:center;

    gap:70px;

    padding:150px 8% 80px;

}

.small-title{

    color:#74b7ff;

    letter-spacing:3px;

    font-size:.9rem;

    margin-bottom:20px;

}

.hero h1{

    font-size:4.8rem;

    line-height:1;

    margin-bottom:25px;

    letter-spacing:-3px;

}

.hero p{

    color:#cfcfcf;

    font-size:1.1rem;

    line-height:1.9;

    max-width:650px;

}

.hero-buttons{

    display:flex;

    gap:18px;

    margin-top:40px;

}

.hero-card{

    padding:45px;

    border-radius:30px;

    background:rgba(255,255,255,.08);

    border:1px solid rgba(255,255,255,.12);

    backdrop-filter:blur(30px);

    transition:.45s;

}

.hero-card:hover{

    transform:translateY(-10px);

    box-shadow:0 25px 60px rgba(0,0,0,.3);

}

.hero-card h3{

    font-size:2rem;

    margin-bottom:20px;

}

/* ==========================
   SECTION TITLE
========================== */

.section-heading{

    text-align:center;

    font-size:3rem;

    margin-bottom:70px;

    letter-spacing:-1px;

}
/* =====================================
   SERVICES
===================================== */

.services{

    padding:120px 8%;

}

.service-grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));

    gap:30px;

}

.service-card{

    background:rgba(255,255,255,.08);

    border:1px solid rgba(255,255,255,.12);

    backdrop-filter:blur(30px);

    border-radius:28px;

    padding:40px;

    transition:.45s ease;

}

.service-card:hover{

    transform:translateY(-12px);

    background:rgba(255,255,255,.12);

    box-shadow:0 30px 70px rgba(0,0,0,.35);

}

.service-card i{

    font-size:42px;

    color:#74b7ff;

    margin-bottom:25px;

}

.service-card h3{

    margin-bottom:15px;

    font-size:1.5rem;

}

.service-card p{

    color:#d0d0d0;

    line-height:1.8;

}

/* =====================================
   PORTFOLIO
===================================== */

.portfolio{

    padding:120px 8%;

}

.portfolio-grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(340px,1fr));

    gap:35px;

}

.portfolio-card{

    overflow:hidden;

    border-radius:30px;

    background:rgba(255,255,255,.06);

    border:1px solid rgba(255,255,255,.12);

    backdrop-filter:blur(20px);

    transition:.45s;

}

.portfolio-card:hover{

    transform:translateY(-10px);

    box-shadow:0 30px 80px rgba(0,0,0,.35);

}

.portfolio-card img{

    width:100%;

    height:260px;

    object-fit:cover;

    transition:.6s;

}

.portfolio-card:hover img{

    transform:scale(1.08);

}

.portfolio-info{

    padding:28px;

}

.portfolio-info h3{

    margin-bottom:10px;

}

.portfolio-info p{

    color:#cfcfcf;

}

/* =====================================
   PRICING
===================================== */

.pricing{

    padding:120px 8%;

}

.pricing-grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));

    gap:35px;

}

.price-card{

    background:rgba(255,255,255,.08);

    border:1px solid rgba(255,255,255,.12);

    backdrop-filter:blur(28px);

    border-radius:30px;

    padding:45px;

    text-align:center;

    transition:.45s;

}

.price-card:hover{

    transform:translateY(-12px);

}

.price-card h1{

    font-size:3rem;

    margin:25px 0;

}

.price-card ul{

    list-style:none;

    margin:30px 0;

}

.price-card li{

    margin:14px 0;

    color:#d6d6d6;

}

.featured{

    transform:scale(1.05);

    border:1px solid rgba(116,183,255,.45);

    box-shadow:0 20px 60px rgba(70,140,255,.25);

}

.popular{

    display:inline-block;

    padding:8px 18px;

    border-radius:999px;

    background:#74b7ff;

    color:#111;

    font-weight:700;

    margin-bottom:18px;

}

/* =====================================
   ABOUT
===================================== */

.about{

    padding:120px 8%;

}

.about-content{

    display:grid;

    grid-template-columns:1.3fr .9fr;

    gap:50px;

    align-items:center;

}

.about h2{

    font-size:3rem;

    margin-bottom:25px;

}

.about p{

    color:#d2d2d2;

    line-height:1.9;

}

.glass-box{

    background:rgba(255,255,255,.08);

    border:1px solid rgba(255,255,255,.12);

    backdrop-filter:blur(30px);

    border-radius:30px;

    padding:40px;

}

.glass-box h3{

    margin-bottom:20px;

}

.glass-box ul{

    list-style:none;

}

.glass-box li{

    margin:16px 0;

    color:#e3e3e3;

}
/* =====================================
   TESTIMONIALS
===================================== */

.testimonials{
    padding:120px 8%;
}

.testimonial-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:30px;
}

.testimonial-card{
    background:rgba(255,255,255,.08);
    backdrop-filter:blur(30px);
    border:1px solid rgba(255,255,255,.12);
    border-radius:28px;
    padding:35px;
    transition:.4s;
}

.testimonial-card:hover{
    transform:translateY(-10px);
    box-shadow:0 25px 60px rgba(0,0,0,.3);
}

.testimonial-card p{
    color:#d8d8d8;
    line-height:1.8;
    margin-bottom:20px;
}

.testimonial-card h4{
    color:#74b7ff;
    margin-bottom:6px;
}

/* =====================================
   FAQ
===================================== */

.faq{
    padding:120px 8%;
}

.faq-item{
    max-width:850px;
    margin:20px auto;
    background:rgba(255,255,255,.08);
    backdrop-filter:blur(25px);
    border:1px solid rgba(255,255,255,.12);
    border-radius:22px;
    padding:28px;
    transition:.35s;
}

.faq-item:hover{
    transform:translateY(-5px);
}

.faq-item h3{
    margin-bottom:15px;
}

.faq-item p{
    color:#d3d3d3;
    line-height:1.8;
}

/* =====================================
   CONTACT
===================================== */

.contact{
    padding:120px 8%;
    text-align:center;
}

.contact-card{
    max-width:650px;
    margin:auto;
    padding:50px;
    border-radius:30px;
    background:rgba(255,255,255,.08);
    backdrop-filter:blur(30px);
    border:1px solid rgba(255,255,255,.12);
}

.contact-card p{
    margin:16px 0;
    color:#d7d7d7;
    font-size:1.05rem;
}

/* =====================================
   FOOTER
===================================== */

footer{
    padding:70px 8%;
    text-align:center;
    border-top:1px solid rgba(255,255,255,.08);
}

footer h2{
    margin-bottom:15px;
}

footer p{
    color:#a9a9a9;
    margin:8px 0;
}

/* =====================================
   SCROLLBAR
===================================== */

::-webkit-scrollbar{
    width:10px;
}

::-webkit-scrollbar-track{
    background:#09090b;
}

::-webkit-scrollbar-thumb{
    background:#444;
    border-radius:50px;
}

::-webkit-scrollbar-thumb:hover{
    background:#74b7ff;
}

/* =====================================
   FADE ANIMATIONS
===================================== */

.hero,
.services,
.portfolio,
.pricing,
.about,
.testimonials,
.faq,
.contact{
    animation:fadeUp 1s ease;
}

@keyframes fadeUp{

    from{
        opacity:0;
        transform:translateY(40px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }

}

/* =====================================
   RESPONSIVE
===================================== */

@media(max-width:992px){

.hero{

    grid-template-columns:1fr;
    text-align:center;
    padding-top:150px;

}

.hero-buttons{

    justify-content:center;

}

.about-content{

    grid-template-columns:1fr;

}

.nav-links{

    display:none;

}

.hero h1{

    font-size:3.2rem;

}

.section-heading{

    font-size:2.4rem;

}

}

@media(max-width:600px){

.hero{

    padding:140px 25px 70px;

}

.services,
.portfolio,
.pricing,
.about,
.testimonials,
.faq,
.contact{

    padding:90px 25px;

}

.hero h1{

    font-size:2.5rem;

}

.hero-buttons{

    flex-direction:column;

}

.btn,
.glass-btn{

    width:100%;
    text-align:center;

}

.hero-card,
.price-card,
.service-card,
.portfolio-card,
.testimonial-card,
.contact-card{

    padding:28px;

}

}
/* Cursor Glow */

.cursor-glow{

position:fixed;

width:22px;

height:22px;

border-radius:50%;

background:rgba(116,183,255,.45);

backdrop-filter:blur(12px);

pointer-events:none;

transform:translate(-50%,-50%);

transition:transform .08s linear;

z-index:9999;

box-shadow:0 0 30px rgba(116,183,255,.6);

}